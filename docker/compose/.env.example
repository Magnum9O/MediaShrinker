# ---------------------------------------------------------------------------
# MediaShrinker — configurazione ambiente
# Copia questo file in .env e personalizza i valori.
# ---------------------------------------------------------------------------

# --- Percorsi host (bind mount) ---
MOVIES_ROOT=/mnt/media/Movies
TV_ROOT=/mnt/media/TVSeries
STAGING_ROOT=/srv/mediashrinker/staging
REPORT_ROOT=/srv/mediashrinker/reports

# --- Web UI ---
MEDIA_PORT=8787

# --- Encoder video ---
# auto       = rileva automaticamente (NVENC > VAAPI > libx265)
# hevc_nvenc = forza GPU NVIDIA
# hevc_vaapi = forza GPU Intel/AMD
# libx265    = forza CPU
MEDIA_ENCODER=auto

# --- Profilo di encoding ---
# space_saver  = massimo risparmio spazio (CQ alto, preset lento)
# balanced     = bilanciato qualità/spazio (default)
# quality      = qualità elevata
# hq           = alta qualità (file più grandi)
MEDIA_ENCODING_PROFILE=balanced

# --- Libreria e job ---
MEDIA_LIBRARY=both
MEDIA_JOBS=1

# --- Sottotitoli / OCR ---
MEDIA_OCR_ENGINE=pgsrip
# PGS = sottotitoli "immagine" tipici dei BluRay (HDMV PGS). Non sono testo ricercabile.
# OCR = conversione di sottotitoli immagine (PGS/VobSub) in sottotitoli testuali (.srt) usando pgsrip+tesseract.
#
# Lingue target OCR (ISO 639-2, separate da virgola).
# Esempio: ita,eng,spa
#
# Nota: per fare OCR di una lingua devi installare anche la tessdata corrispondente (vedi TESSDATA_LANGS).
MEDIA_OCR_LANGS=ita,eng
# Se 0: non esegue il percorso di estrazione PGS/OCR (anche se MEDIA_OCR_ENGINE=pgsrip).
MEDIA_EXTRACT_PGS=1
# Se 1: se trova .srt/.ass esterni accanto al video, li aggiunge SOLO quando il file viene gia' processato.
MEDIA_ADD_EXTERNAL_TEXT_SUBS=1

# --- Comportamento file ---
MEDIA_DELETE_BAK=0
MEDIA_BITRATE_THRESHOLD_MBPS=55.0
MEDIA_BITRATE_4K_MBPS=45.0
MEDIA_NO_MULTIPASS=0

# --- Notifiche push (ntfy o compatibile) ---
# Lasciare vuoto per disabilitare.
# Esempi: https://ntfy.sh/mio-canale  oppure  http://ntfy.lan/mediashrinker
MEDIA_NOTIFY_URL=

# --- Demone periodico (profilo watchd) ---
# Intervallo in secondi tra un RUN e il successivo (default 3600 = 1 ora).
# Esempio: 14400 = ogni 4 ore.
MEDIA_WATCH_INTERVAL=3600

# --- Build-time: user e tessdata ---
# PUID e PGID devono corrispondere all'utente/gruppo che possiede i file sul mount host,
# altrimenti il container potrebbe non riuscire a rinominare/sostituire i file.
PUID=1000
PGID=1000
# Spazio-separato: pacchetti apt tesseract-ocr-XXX da installare nel build.
# Supportati: eng ita fra deu spa por nld pol rus jpn chi-sim ...
TESSDATA_LANGS=eng ita
