# ---------------------------------------------------------------------------
# MediaShrinker — environment configuration
# Copy this file to .env and edit the values for your host.
# ---------------------------------------------------------------------------

# --- Host paths (bind mounts) ---
MOVIES_ROOT=/mnt/media/Movies
TV_ROOT=/mnt/media/TVSeries
STAGING_ROOT=/srv/mediashrinker/staging
REPORT_ROOT=/srv/mediashrinker/reports

# --- Web UI ---
MEDIA_PORT=8787

# --- Video encoder ---
# auto       = auto-detect (NVENC > VAAPI > libx265)
# hevc_nvenc = force NVIDIA GPU
# hevc_vaapi = force Intel/AMD GPU
# libx265    = force CPU
MEDIA_ENCODER=auto

# --- Encoding profile ---
# space_saver  = minimum size
# balanced     = quality/size balance (default)
# quality      = higher quality
# hq           = maximum quality (larger files)
MEDIA_ENCODING_PROFILE=balanced

# --- Library and jobs ---
MEDIA_LIBRARY=both
MEDIA_JOBS=1

# --- Subtitles / OCR ---
MEDIA_OCR_ENGINE=pgsrip
# PGS = BluRay image subtitles (HDMV PGS). They are not searchable text.
# OCR = converts image subtitles (PGS/VobSub) to text subtitles (.srt) using pgsrip + tesseract.
#
# OCR target languages (ISO 639-2, comma-separated), e.g. ita,eng,spa
# Note: if you add a language here you must also install the corresponding tessdata pack (see TESSDATA_LANGS).
MEDIA_OCR_LANGS=ita,eng
# If 0: disables PGS extraction/OCR path (even if MEDIA_OCR_ENGINE=pgsrip).
MEDIA_EXTRACT_PGS=1
# If 1: mux external .srt/.ass found next to the video when the file is processed.
MEDIA_ADD_EXTERNAL_TEXT_SUBS=1

# --- File behavior ---
MEDIA_DELETE_BAK=0
MEDIA_BITRATE_THRESHOLD_MBPS=55.0
MEDIA_BITRATE_4K_MBPS=45.0
MEDIA_NO_MULTIPASS=0

# --- Push notifications (ntfy compatible) ---
# Leave empty to disable.
# Examples: https://ntfy.sh/your-topic or http://ntfy.lan/mediashrinker
MEDIA_NOTIFY_URL=

# --- Periodic daemon (watchd profile) ---
# Seconds between each RUN (default 3600 = 1 hour). Example: 14400 = every 4 hours.
MEDIA_WATCH_INTERVAL=3600

# --- Build-time: tessdata ---
# Space-separated apt packages to install at build time: tesseract-ocr-XXX
# Common ones: eng ita fra deu spa por nld pol rus jpn chi-sim ...
TESSDATA_LANGS=eng ita
