# ---------------------------------------------------------------------------
# Di solito devi cambiare manualmente solo questi 4 path.
# Il resto ha gia' un default operativo sensato per partire.
# ---------------------------------------------------------------------------
MOVIES_ROOT=/volume1/Media/Movies
TV_ROOT=/volume1/Media/TV
STAGING_ROOT=/volume1/docker/mediashrinker/staging
REPORT_ROOT=/volume1/docker/mediashrinker/reports

# Opzionale: cambia solo se ti serve una porta diversa
MEDIA_PORT=8787
MEDIA_ENCODER=hevc_vaapi
MEDIA_ENCODING_PROFILE=balanced
MEDIA_LIBRARY=both
MEDIA_JOBS=1

MEDIA_OCR_ENGINE=pgsrip
MEDIA_OCR_LANGS=ita,eng
MEDIA_EXTRACT_PGS=1
MEDIA_ADD_EXTERNAL_TEXT_SUBS=1

MEDIA_DELETE_BAK=0
MEDIA_BITRATE_THRESHOLD_MBPS=55.0
MEDIA_BITRATE_4K_MBPS=45.0
MEDIA_NO_MULTIPASS=0

MEDIA_NOTIFY_URL=
MEDIA_WATCH_INTERVAL=3600

# Opzionale: cambia solo se ownership / permessi del NAS sono diversi
PUID=1026
PGID=100
TESSDATA_LANGS=eng ita
